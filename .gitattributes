# Normalize line endings on commit; checkout uses platform default.
* text=auto eol=lf

# Explicit text files
*.js       text eol=lf
*.mjs      text eol=lf
*.ts       text eol=lf
*.json     text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.svg      text eol=lf
*.sh       text eol=lf
LICENSE    text eol=lf

# Binary — never touch
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.zip      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.otf      binary
